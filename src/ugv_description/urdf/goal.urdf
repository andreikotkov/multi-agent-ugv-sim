<?xml version="1.0"?>
<robot name="goal_flag">
  
  <gazebo>
    <static>true</static>
  </gazebo>

  <link name="flag_link">
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="1.0"/>
      </geometry>
    </visual>
  </link>

  <gazebo reference="flag_link">
    <material>Gazebo/Red</material>
  </gazebo>

</robot>